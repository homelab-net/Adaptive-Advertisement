# Adaptive Advertisement — environment variable overrides
#
# Copy to .env and customise for your deployment.
# docker compose automatically loads .env from the project root.
#
# All defaults are safe for local development; override for production.

# ── postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard
POSTGRES_DB=dashboard

# ── dashboard-api (prefix: DASHBOARD_) ───────────────────────────────────
DASHBOARD_DATABASE_URL=postgresql+asyncpg://dashboard:dashboard@postgres:5432/dashboard
DASHBOARD_LOG_LEVEL=INFO

# ── player ────────────────────────────────────────────────────────────────
# Switch to "mpv" on Jetson hardware with a display attached.
RENDERER_BACKEND=stub

# ── supervisor ────────────────────────────────────────────────────────────
RESTART_THRESHOLD=5
BOOT_LOOP_THRESHOLD=3
FAST_FAIL_WINDOW_S=120

# ── log level (all services) ──────────────────────────────────────────────
LOG_LEVEL=INFO
