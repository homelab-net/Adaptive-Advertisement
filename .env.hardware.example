# Adaptive Advertisement — hardware deployment env template
#
# Copy to .env.hardware and fill in site-specific values.
# Compose usage:
#   docker compose -f docker-compose.yml -f docker-compose.hardware.yml --env-file .env.hardware up -d --build

# --- Identity and tenancy ---
TENANT_ID=default-tenant
SITE_ID=site-01
CAMERA_ID=cam-main-01

# --- Player ---
# Hardware profile defaults to mpv via docker-compose.hardware.yml
RENDERER_BACKEND=mpv

# --- input-cv ---
# Hardware profile defaults to deepstream via docker-compose.hardware.yml
INPUT_CV_PIPELINE_BACKEND=deepstream
INPUT_CV_CONFIG_PATH=/config/camera-source.json

# --- MQTT ---
MQTT_HOST=mosquitto
MQTT_PORT=1883

# --- Dashboard / DB ---
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard
POSTGRES_DB=dashboard
DASHBOARD_DATABASE_URL=postgresql+asyncpg://dashboard:dashboard@postgres:5432/dashboard

# --- Logging ---
LOG_LEVEL=INFO
